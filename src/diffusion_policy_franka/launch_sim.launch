<!-- ═══════════════════════════════════════════════════════════════════
     Sim mode — drives PyBullet arm via Polymetis

     Start the sim server manually before roslaunch:
         launch_robot.py robot_client=bullet_sim gui=true

     Usage:
         # Controller test only (no policy, no checkpoint needed):
         roslaunch diffusion_policy_franka diffusion_policy_sim.launch

         # Full pipeline (needs checkpoint + observation source):
         roslaunch diffusion_policy_franka diffusion_policy_sim.launch \
             use_sim_node:=false \
             checkpoint_path:=/path/to/latest.ckpt
═══════════════════════════════════════════════════════════════════ -->
<launch>

  <!-- ── args ──────────────────────────────────────────────────────── -->
  <arg name="checkpoint_path"     default="/tmp/latest.ckpt"/>
  <arg name="device"              default="cuda:0"/>
  <arg name="num_inference_steps" default="10"/>
  <arg name="n_obs_steps"         default="2"/>
  <arg name="output_dir"          default="/tmp/eval_real_output"/>
  <arg name="action_hz"           default="10.0"/>
  <arg name="interp_hz"           default="50.0"/>   <!-- lower for sim -->
  <arg name="amplitude"           default="0.03"/>
  <arg name="n_action_steps"      default="8"/>

  <!-- set false to run full policy pipeline instead of sim_node -->
  <arg name="use_sim_node"        default="true"/>

  <!-- ── sim_node: feeds fake action chunks directly ───────────────── -->
  <!-- active when use_sim_node=true — bypasses observation + policy   -->
  <group if="$(arg use_sim_node)">
    <node name="sim_node"
          pkg="diffusion_policy_franka"
          type="sim_node.py"
          output="screen">
      <param name="action_hz"       value="$(arg action_hz)"/>
      <param name="n_action_steps"  value="$(arg n_action_steps)"/>
      <param name="amplitude"       value="$(arg amplitude)"/>
    </node>
  </group>

  <!-- ── full policy pipeline ──────────────────────────────────────── -->
  <!-- active when use_sim_node=false                                  -->
  <group unless="$(arg use_sim_node)">

    <node name="observation_node"
          pkg="diffusion_policy_franka"
          type="observation_node.py"
          output="screen">
      <param name="n_obs_steps" value="$(arg n_obs_steps)"/>
      <param name="publish_hz"  value="$(arg action_hz)"/>
      <!-- sim publishes on /sim/ topics from digital_twin_node -->
      <param name="cam1_topic"  value="/sim/eih/color/image_raw"/>
      <param name="cam2_topic"  value="/sim/ext/color/image_raw"/>
    </node>

    <node name="eval_real"
          pkg="diffusion_policy_franka"
          type="eval_real.py"
          output="screen"
          launch-prefix="taskset -c 4,5,6,7">
      <param name="checkpoint_path"     value="$(arg checkpoint_path)"/>
      <param name="device"              value="$(arg device)"/>
      <param name="num_inference_steps" value="$(arg num_inference_steps)"/>
      <param name="n_obs_steps"         value="$(arg n_obs_steps)"/>
      <param name="output_dir"          value="$(arg output_dir)"/>
    </node>

  </group>

  <!-- ── controller_node — always running ──────────────────────────── -->
  <node name="controller_node"
        pkg="diffusion_policy_franka"
        type="controller_node.py"
        output="screen">
    <param name="mode"      value="sim"/>
    <param name="action_hz" value="$(arg action_hz)"/>
    <param name="interp_hz" value="$(arg interp_hz)"/>
    <!-- robot_ip not needed for sim — uses localhost -->
  </node>

</launch>