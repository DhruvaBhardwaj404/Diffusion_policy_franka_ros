<!-- ═══════════════════════════════════════════════════════════════════
     Sim mode — drives PyBullet arm via Polymetis

     Start the sim server manually before roslaunch:
         launch_robot.py robot_client=bullet_sim gui=true

     Usage:
         # NPZ demo replay → full policy pipeline:
         roslaunch diffusion_policy_franka diffusion_policy_sim.launch \
             npz_path:=/path/to/demo.npz \
             checkpoint_path:=/path/to/latest.ckpt

         # NPZ replay, looping:
         roslaunch diffusion_policy_franka diffusion_policy_sim.launch \
             npz_path:=/path/to/demo.npz \
             loop:=true \
             checkpoint_path:=/path/to/latest.ckpt

         # Skip sim_node — use a live digital twin or other image source:
         roslaunch diffusion_policy_franka diffusion_policy_sim.launch \
             use_sim_node:=false \
             checkpoint_path:=/path/to/latest.ckpt
═══════════════════════════════════════════════════════════════════ -->
<launch>

  <!-- ── args ──────────────────────────────────────────────────────── -->
  <arg name="checkpoint_path"     default="/tmp/latest.ckpt"/>
  <arg name="device"              default="cuda:0"/>
  <arg name="output_dir"          default="/tmp/eval_real_output"/>
  <arg name="action_hz"           default="10.0"/>
  <arg name="interp_hz"           default="50.0"/>

  <!-- sim_node NPZ replay args -->
  <arg name="npz_path"            default=""/>       <!-- required if use_sim_node=true -->
  <arg name="loop"                default="false"/>

  <!-- set false if using a digital twin or other live image source -->
  <arg name="use_sim_node"        default="true"/>

  <!-- ── sim_node: replays raw sensor data from NPZ onto sensor topics ── -->
  <!-- observation_node subscribes to these same topics and preprocesses  -->
  <group if="$(arg use_sim_node)">
    <node name="sim_node"
          pkg="diffusion_policy_franka"
          type="sim_node.py"
          output="screen"
          args="--npz $(arg npz_path) --replay_hz $(arg action_hz) $(eval '--loop' if arg('loop') == 'true' else '')">
      <!-- topics must match observation_node's cam1/cam2 params below -->
      <param name="cam1_topic"    value="/eih/color/image_raw"/>
      <param name="cam2_topic"    value="/ext/color/image_raw"/>
      <param name="joint_topic"   value="/franka_state_controller/joint_states"/>
      <param name="gripper_topic" value="/franka_gripper/joint_states"/>
    </node>
  </group>

  <!-- ── observation_node — always running ─────────────────────────── -->
  <!-- When use_sim_node=true:  receives raw data from sim_node above   -->
  <!-- When use_sim_node=false: receives data from digital twin / other -->
  <node name="observation_node"
        pkg="diffusion_policy_franka"
        type="observation_node.py"
        output="screen">
    <param name="n_obs_steps" value="$(arg n_obs_steps)"/>
    <param name="publish_hz"  value="$(arg action_hz)"/>
    <!-- When use_sim_node=true these match sim_node's output topics.   -->
    <!-- When use_sim_node=false point at your digital twin topics.     -->
    <param name="cam1_topic"  value="/eih/color/image_raw"/>
    <param name="cam2_topic"  value="/ext/color/image_raw"/>
  </node>

  <!-- ── controller_node — always running ──────────────────────────── -->
  <!-- Receives action chunks and drives PyBullet via Polymetis         -->
  <node name="controller_node"
        pkg="diffusion_policy_franka"
        type="controller_node.py"
        output="screen">
    <param name="mode"      value="sim"/>
    <param name="action_hz" value="$(arg action_hz)"/>
    <param name="interp_hz" value="$(arg interp_hz)"/>
    <!-- robot_ip not needed for sim — uses localhost -->
  </node>

</launch>