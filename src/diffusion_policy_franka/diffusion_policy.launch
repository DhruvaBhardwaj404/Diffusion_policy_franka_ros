<launch>

  <!-- ═══════════════════════════════════════════════════════════════════
       roslaunch franka_diffusion_policy diffusion_policy.launch \
           checkpoint_path:=/path/to/latest.ckpt device:=cuda
  ═══════════════════════════════════════════════════════════════════════ -->
  <arg name="checkpoint_path"     default="/home/user/checkpoints/latest.ckpt"/>
  <arg name="device"              default="cuda"/>
  <arg name="use_torch_compile"   default="false"/>

  <!-- camera topics — must match data collector params exactly -->
  <arg name="cam1_topic" default="/eih/color/image_raw"/>   <!-- wrist cam -->
  <arg name="cam2_topic" default="/ext/color/image_raw"/>   <!-- external cam -->

  <!-- ══════════════════ observation_node ════════════════════════════ -->
  <node name="observation_node"
        pkg="franka_diffusion_policy"
        type="observation_node.py"
        output="screen">
    <param name="n_obs_steps"  value="$(arg n_obs_steps)"/>
    <param name="publish_hz"   value="10"/>
    <param name="cam1_topic"   value="$(arg cam1_topic)"/>
    <param name="cam2_topic"   value="$(arg cam2_topic)"/>
  </node>

  <!-- ══════════════════ policy_node ════════════════════════════════ -->
  <!-- pinned to cores 4-7 to avoid competing with controller on 0-3  -->
  <node name="policy_node"
        pkg="franka_diffusion_policy"
        type="policy_node.py"
        output="screen"
        launch-prefix="taskset -c 4,5,6,7">
    <param name="checkpoint_path"     value="$(arg checkpoint_path)"/>
    <param name="device"              value="$(arg device)"/>
    <param name="num_inference_steps" value="$(arg num_inference_steps)"/>
    <param name="use_torch_compile"   value="$(arg use_torch_compile)"/>
    <param name="n_obs_steps"         value="$(arg n_obs_steps)"/>
  </node>

  <!-- ══════════════════ controller_node ════════════════════════════ -->
  <node name="controller_node"
        pkg="franka_diffusion_policy"
        type="controller_node.py"
        output="screen">
    <param name="action_hz"      value="10.0"/>
    <param name="control_hz"     value="100.0"/>  <!-- dense interp rate -->
    <param name="max_cart_step"  value="0.05"/>   <!-- metres per action step -->
  </node>

</launch>